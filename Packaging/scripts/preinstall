#!/bin/bash
# preinstall for PriTypeV2.pkg

# 1. Kill existing PriTypeV2 process first (before deleting)
#    macOS IMK will auto-relaunch it after postinstall finishes.
killall PriTypeV2 2>/dev/null || true

# 2. Small delay to ensure the process has fully terminated
sleep 0.5

# 3. Remove old installations to ensure a clean install
rm -rf "/Library/Input Methods/PriTypeV2.app"
rm -rf "/Library/Input Methods/PriType.app"

# Remove from all user home directories (in case of previous relocated installs)
for user_home in /Users/*; do
    rm -rf "$user_home/Library/Input Methods/PriTypeV2.app"
    rm -rf "$user_home/Library/Input Methods/PriType.app"
done

exit 0
